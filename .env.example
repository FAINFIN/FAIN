# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (Resend — https://resend.com) ─────────────────
RESEND_API_KEY=re_...
RESEND_FROM=Fain <noreply@yourdomain.com>

# ─── Salt Edge (https://www.saltedge.com/client_users) ───
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v5

# ─── Upstash Redis (https://console.upstash.com) ─────────
# Optional — rate limiting + magic link token TTL.
# If omitted the app uses in-memory fallbacks (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
